/* components/emoji-picker/emoji-picker.wxss - Swancam Dark */

.emoji-picker {
  background: rgba(28, 28, 30, 0.98);
  border-radius: 40rpx 40rpx 0 0;
  padding-bottom: calc(env(safe-area-inset-bottom) + 16rpx);
}

/* ── 头部 ────────────────────────────────────── */
.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.popup-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--swancam-text-primary);
}

.popup-close {
  font-size: 28rpx;
  color: var(--swancam-text-tertiary);
  padding: 8rpx 16rpx;
  transition: opacity 0.2s;
}
.popup-close:active { opacity: 0.5; }

/* ── 分类 Tab 横向滚动 ───────────────────────── */
.category-tabs {
  padding: 16rpx 0 8rpx;
}

.category-scroll {
  display: flex;
  padding: 0 24rpx;
  gap: 10rpx;
}

.category-tab {
  flex-shrink: 0;
  padding: 10rpx 28rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  color: var(--swancam-text-secondary);
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  transition: all var(--duration-fast) var(--ease-out-expo);
}
.category-tab:active { opacity: 0.7; }

.category-tab.active {
  background: var(--swancam-primary);
  color: #FFFFFF;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(255, 45, 85, 0.3);
}

/* ── Emoji 网格 ──────────────────────────────── */
.emoji-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx 20rpx 24rpx;
  gap: 6rpx;
}

.emoji-item {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  border-radius: var(--radius-sm);
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid transparent;
  transition: background var(--duration-fast), transform var(--duration-fast);
}
.emoji-item:active {
  background: rgba(255, 45, 85, 0.12);
  border-color: rgba(255, 45, 85, 0.25);
  transform: scale(0.88);
}
