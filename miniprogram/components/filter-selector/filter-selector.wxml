<!-- components/filter-selector/filter-selector.wxml -->
<view class="filter-selector">
  <!-- 强度调节 -->
  <view class="intensity-row">
    <text class="intensity-label">强度</text>
    <slider
      class="intensity-slider"
      min="0"
      max="100"
      value="{{intensity}}"
      activeColor="#FF2D55"
      backgroundColor="rgba(255,255,255,0.1)"
      block-color="#FFFFFF"
      bindchange="onIntensityChange"
      bindchanging="onIntensityChange"
    />
    <text class="intensity-value">{{intensity}}%</text>
  </view>

  <!-- 滤镜列表 -->
  <scroll-view class="filter-scroll-view" scroll-x show-scrollbar="{{false}}">
    <view class="filter-scroll">
      <view
        class="filter-item {{item.id === selectedId ? 'active' : ''}}"
        wx:for="{{filters}}"
        wx:key="id"
        bindtap="selectFilter"
        data-id="{{item.id}}"
      >
        <view class="filter-thumb-wrap">
          <image
            class="filter-thumb"
            src="{{previewSrc}}"
            mode="aspectFill"
          />
          <view class="filter-thumb-mask" wx:if="{{item.id !== 'original'}}"></view>
        </view>
        <text class="filter-name">{{item.name}}</text>
        <text class="filter-desc">{{item.desc}}</text>
      </view>
    </view>
  </scroll-view>
</view>
