/* components/filter-selector/filter-selector.wxss - Swancam Dark */

.filter-selector {
  background: var(--swancam-surface);
}

/* ── 强度调节行 ──────────────────────────────── */
.intensity-row {
  display: flex;
  align-items: center;
  padding: 12rpx 32rpx;
  gap: 16rpx;
}

.intensity-label {
  font-size: 24rpx;
  color: var(--swancam-text-tertiary);
  white-space: nowrap;
}

.intensity-slider { flex: 1; }

.intensity-value {
  font-size: 24rpx;
  color: var(--swancam-text-secondary);
  width: 64rpx;
  text-align: right;
}

/* ── 滤镜横向列表 ────────────────────────────── */
.filter-scroll-view { width: 100%; }

.filter-scroll {
  display: flex;
  padding: 8rpx 16rpx 16rpx;
  gap: 16rpx;
}

.filter-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
  opacity: 0.7;
  transition: opacity var(--duration-fast) var(--ease-out-expo),
              transform var(--duration-fast) var(--ease-out-expo);
}
.filter-item.active {
  opacity: 1;
  transform: translateY(-4rpx);
}
.filter-item:active { opacity: 0.45; }

/* 缩略图 */
.filter-thumb-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  position: relative;
  border: 3rpx solid transparent;
  transition: border-color var(--duration-fast) var(--ease-out-expo);
}
.filter-item.active .filter-thumb-wrap {
  border-color: var(--swancam-primary);
  box-shadow: 0 4rpx 16rpx rgba(255, 45, 85, 0.3);
}

.filter-thumb { width: 100%; height: 100%; }

.filter-thumb-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.1);
}

/* 滤镜名 */
.filter-name {
  font-size: 22rpx;
  color: var(--swancam-text-tertiary);
  transition: color var(--duration-fast);
}
.filter-item.active .filter-name {
  color: var(--swancam-primary);
  font-weight: 600;
}

/* 滤镜描述 */
.filter-desc {
  font-size: 18rpx;
  color: var(--swancam-text-tertiary);
  opacity: 0.6;
  max-width: 100rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
