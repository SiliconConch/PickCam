/* pages/profile/profile.wxss - Swancam Refined Profile Experience */

/* ── C8: 导航栏 ── */
.profile-nav {
  display: flex; align-items: center; justify-content: space-between;
  padding: calc(env(safe-area-inset-top) + 24rpx) 32rpx 24rpx;
  background: rgba(0,0,0,0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1rpx solid rgba(255,255,255,0.05);
  position: sticky; top: 0; z-index: 100;
}
.profile-nav-back {
  font-size: 52rpx; color: var(--swancam-text-primary);
  width: 64rpx; line-height: 1; padding: 0 8rpx;
}
.profile-nav-back:active { opacity: 0.5; }
.profile-nav-title {
  font-size: 32rpx; font-weight: var(--font-weight-bold);
  color: var(--swancam-text-primary); letter-spacing: 2rpx;
}
.profile-nav-placeholder { width: 64rpx; }

.profile-page {
  min-height: 100vh;
  background: var(--swancam-bg);
  padding-bottom: 80rpx;
}

/* ── 用户信息卡 (Glassmorphism) ── */
.user-card {
  background: rgba(28, 28, 30, 0.8);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  margin: 32rpx 32rpx 0;
  border-radius: var(--radius-lg);
  padding: 48rpx 32rpx 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  overflow: hidden;
  position: relative;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
}
.user-card-bg {
  position: absolute;
  top: -80rpx; right: -80rpx;
  width: 400rpx; height: 400rpx;
  border-radius: 50%;
  background: radial-gradient(circle, var(--swancam-primary-light) 0%, transparent 70%);
  pointer-events: none;
}
.user-info-row {
  display: flex; align-items: center; gap: 32rpx;
  margin-bottom: 48rpx;
}
.avatar-wrap { flex-shrink: 0; }
.user-avatar {
  width: 112rpx; height: 112rpx;
  border-radius: 50%;
  border: 3rpx solid var(--swancam-primary);
  box-shadow: 0 0 20rpx var(--swancam-primary-light);
}
.user-avatar-ph {
  width: 112rpx; height: 112rpx; border-radius: 50%;
  background: rgba(255, 45, 85, 0.1);
  border: 2rpx dashed var(--swancam-primary);
  display: flex; align-items: center; justify-content: center;
}
.avatar-ph-text { font-size: 48rpx; color: var(--swancam-primary); opacity: 0.6; }
.user-text { flex: 1; }
.user-name  { display: block; font-size: 36rpx; font-weight: bold; color: var(--swancam-text-primary); margin-bottom: 8rpx; }
.user-since { display: block; font-size: 22rpx; color: var(--swancam-text-tertiary); }
.edit-profile-btn {
  padding: 12rpx 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.05);
  border-radius: var(--radius-full);
  flex-shrink: 0;
}
.edit-btn-text { font-size: 22rpx; color: var(--swancam-text-secondary); }

.stats-row {
  display: flex; align-items: center;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  padding: 32rpx 0 0;
}
.stat-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.stat-num   { font-size: 40rpx; font-weight: bold; color: var(--swancam-text-primary); }
.stat-label { font-size: 20rpx; color: var(--swancam-text-tertiary); text-transform: uppercase; letter-spacing: 1rpx; }
.stat-divider { width: 1rpx; height: 48rpx; background: rgba(255, 255, 255, 0.1); flex-shrink: 0; }

/* ── 分区标题 ── */
.section-head {
  margin: 48rpx 40rpx 16rpx;
}
.section-title {
  display: block;
  font-size: 28rpx; font-weight: bold;
  color: var(--swancam-text-primary); margin-bottom: 6rpx;
}
.section-sub {
  display: block;
  font-size: 20rpx; color: var(--swancam-text-tertiary);
}

/* ── 偏好设置块 ── */
.pref-block {
  margin: 0 32rpx 24rpx;
  background: rgba(28, 28, 30, 0.6);
  border-radius: var(--radius-lg);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  padding: 32rpx;
}
.pref-label {
  display: block;
  font-size: 24rpx; color: var(--swancam-text-secondary);
  margin-bottom: 24rpx;
  font-weight: bold;
}

/* 默认滤镜滚动容器 */
.pref-filter-scroll { width: 100%; }
.pref-tmpl-scroll   { width: 100%; }

/* 默认滤镜滚动条 */
.pref-filter-row {
  display: flex; gap: 16rpx;
}
.pref-filter-pill {
  flex-shrink: 0;
  display: flex; align-items: center; gap: 12rpx;
  padding: 12rpx 24rpx 12rpx 12rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: var(--radius-full);
  border: 1rpx solid transparent;
  transition: all var(--duration-fast) var(--ease-out-expo);
}
.pref-filter-pill.active {
  background: var(--swancam-primary-light);
  border-color: var(--swancam-primary);
}
.pref-filter-pill.active .pref-filter-name { color: var(--swancam-primary); font-weight: bold; }
.pref-swatch {
  width: 24rpx; height: 24rpx;
  border-radius: 50%;
}
.pref-filter-name { font-size: 24rpx; color: var(--swancam-text-secondary); }

/* 默认水印模板 */
.pref-tmpl-row { display: flex; gap: 16rpx; }
.pref-tmpl-card {
  flex-shrink: 0;
  width: 140rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: var(--radius-md);
  padding: 20rpx;
  border: 2rpx solid transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  transition: all var(--duration-fast) var(--ease-out-expo);
}
.pref-tmpl-card.active { border-color: var(--swancam-primary); background: var(--swancam-primary-light); }
.pref-tmpl-bar {
  width: 32rpx; height: 4rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 2rpx;
}
.pref-tmpl-card.active .pref-tmpl-bar { background: var(--swancam-primary); }
.pref-tmpl-name {
  font-size: 22rpx; color: var(--swancam-text-secondary);
  text-align: center;
}
.pref-tmpl-card.active .pref-tmpl-name { color: var(--swancam-primary); font-weight: bold; }

/* 水印位置 九宫格 */
.pos-grid-mini {
  display: grid;
  grid-template-columns: repeat(3, 80rpx);
  gap: 12rpx;
}
.pos-cell-mini {
  width: 80rpx; height: 80rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: var(--radius-sm);
  display: flex; align-items: center; justify-content: center;
  border: 1rpx solid transparent;
  transition: all var(--duration-fast) var(--ease-out-expo);
}
.pos-cell-mini.active {
  background: var(--swancam-primary-light);
  border-color: var(--swancam-primary);
}
.pos-label-mini { font-size: 24rpx; color: var(--swancam-text-tertiary); }
.pos-cell-mini.active .pos-label-mini { color: var(--swancam-primary); font-weight: bold; }

/* 透明度滑杆行 */
.pref-slider-row {
  display: flex; align-items: center; gap: 24rpx;
}
.pref-sl { flex: 1; margin: 0; }
.pref-slider-val {
  font-size: 24rpx; color: var(--swancam-text-secondary);
  width: 64rpx; text-align: right; flex-shrink: 0;
}

/* ── 菜单区 ── */
.menu-section { margin: 32rpx 32rpx 0; }
.menu-section-title {
  font-size: 24rpx;
  font-weight: bold;
  color: var(--swancam-text-tertiary);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  display: block;
}
.menu-list {
  background: rgba(28, 28, 30, 0.6);
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}
.menu-item {
  display: flex; align-items: center; gap: 24rpx;
  padding: 32rpx 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}
.menu-item:active { background: rgba(255, 255, 255, 0.04); }
.menu-last { border-bottom: none; }
.menu-icon  { font-size: 32rpx; width: 48rpx; text-align: center; }
.menu-label { flex: 1; font-size: 28rpx; color: var(--swancam-text-secondary); }
.menu-arrow { font-size: 32rpx; color: var(--swancam-text-tertiary); opacity: 0.5; }

/* ── 退出 ── */
.logout-wrap { margin: 48rpx 32rpx 0; }
.logout-btn {
  padding: 32rpx;
  background: rgba(255, 45, 85, 0.05);
  border: 1rpx solid rgba(255, 45, 85, 0.2);
  border-radius: var(--radius-lg);
  text-align: center;
  font-size: 28rpx;
  color: var(--swancam-primary);
  font-weight: bold;
}
.logout-btn:active { opacity: 0.7; }

/* ── 底部版权 ── */
.profile-footer {
  margin-top: 80rpx;
  display: flex; flex-direction: column;
  align-items: center; gap: 12rpx;
}
.footer-version { font-size: 22rpx; color: var(--swancam-text-tertiary); }
.footer-copy    { font-size: 20rpx; color: var(--swancam-text-tertiary); opacity: 0.5; }
