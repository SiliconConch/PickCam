/* pages/splash/splash.wxss */

.splash-page {
  width: 100vw;
  height: 100vh;
  background: #060606;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

/* ── 背景光晕 ── */
.bg-glow {
  position: absolute;
  width: 800rpx;
  height: 800rpx;
  border-radius: 50%;
  background: radial-gradient(
    circle,
    rgba(212,165,116,0.14) 0%,
    rgba(212,165,116,0.05) 45%,
    transparent 72%
  );
  top: 50%;
  left: 50%;
  transform: translate(-50%, -62%);
  pointer-events: none;
}

/* ── Logo 镜头 ── */
.logo-wrap {
  width: 256rpx;
  height: 256rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 56rpx;

  opacity: 0;
  transform: scale(0.35);
  transition: opacity 0.55s ease, transform 0.65s cubic-bezier(0.34, 1.4, 0.64, 1);
}
.logo-wrap.logo-in {
  opacity: 1;
  transform: scale(1);
}

/* 同心圆环 */
.lens-ring {
  position: absolute;
  border-radius: 50%;
}
.lr-outer {
  width: 256rpx;
  height: 256rpx;
  border: 2rpx solid rgba(212,165,116,0.22);
  animation: slowspin 18s linear infinite;
}
.lr-mid {
  width: 178rpx;
  height: 178rpx;
  border: 2rpx solid rgba(212,165,116,0.45);
  animation: slowspin 10s linear infinite reverse;
}

/* 镜头核心 */
.lens-core {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: radial-gradient(
    circle,
    rgba(212,165,116,0.85) 0%,
    rgba(212,165,116,0.35) 55%,
    transparent 100%
  );
  display: flex;
  align-items: center;
  justify-content: center;
  position: absolute;
}
.lens-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #FFFFFF;
  box-shadow: 0 0 24rpx 6rpx rgba(255,255,255,0.55);
}

/* 光圈线（三条，各 60°） */
.aperture-line {
  position: absolute;
  width: 236rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(212,165,116,0.18), transparent);
}
.al-0 { transform: rotate(0deg); }
.al-1 { transform: rotate(60deg); }
.al-2 { transform: rotate(120deg); }

@keyframes slowspin {
  to { transform: rotate(360deg); }
}

/* ── 品牌文字 ── */
.brand-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 32rpx;

  opacity: 0;
  transform: translateY(28rpx);
  transition: opacity 0.5s ease, transform 0.55s ease;
}
.brand-block.brand-in {
  opacity: 1;
  transform: translateY(0);
}
.brand-zh {
  font-size: 56rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 10rpx;
}
.brand-rule {
  width: 48rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #D4A574, transparent);
  border-radius: 1rpx;
}
.brand-en {
  font-size: 20rpx;
  color: rgba(212,165,116,0.65);
  letter-spacing: 7rpx;
  font-weight: 300;
}

/* ── 标语 ── */
.tagline {
  font-size: 26rpx;
  color: rgba(255,255,255,0.32);
  letter-spacing: 2rpx;
  margin-bottom: 96rpx;
  opacity: 0;
  transition: opacity 0.6s ease;
}
.tagline.tagline-in { opacity: 1; }

/* ── 加载点 ── */
.dots-wrap {
  display: flex;
  gap: 14rpx;
  opacity: 0;
  transition: opacity 0.4s ease;
}
.dots-wrap.dots-in { opacity: 1; }
.ldot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(212,165,116,0.5);
}
.d1 { animation: dotbeat 1.4s 0s   ease-in-out infinite; }
.d2 { animation: dotbeat 1.4s 0.22s ease-in-out infinite; }
.d3 { animation: dotbeat 1.4s 0.44s ease-in-out infinite; }
@keyframes dotbeat {
  0%, 100% { transform: scale(0.6); opacity: 0.35; }
  50%       { transform: scale(1);   opacity: 1;    }
}
