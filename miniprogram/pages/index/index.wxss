/* pages/index/index.wxss - Swancam Dark Index */

.index-page {
  min-height: 100vh;
  background: var(--swancam-bg);
  display: flex;
  flex-direction: column;
  padding: 0 32rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 32rpx);
}

/* ── 品牌区 ─────────────────────────────────── */
.brand-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 64rpx;
}

.brand-logo-wrap {
  width: 112rpx;
  height: 112rpx;
  background: var(--swancam-primary-light);
  border: 2rpx solid rgba(255, 45, 85, 0.3);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.brand-logo-icon {
  font-size: 52rpx;
  color: var(--swancam-primary);
}

.brand-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--swancam-text-primary);
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.brand-sub {
  font-size: 24rpx;
  color: var(--swancam-text-tertiary);
  letter-spacing: 1rpx;
}

/* ── 操作区 ─────────────────────────────────── */
.action-area {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 48rpx;
}

.action-primary,
.action-secondary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-radius: 20rpx;
  border: 1rpx solid transparent;
  transition: transform 0.2s var(--ease-out-expo), opacity 0.2s;
}
.action-primary:active,
.action-secondary:active { opacity: 0.85; transform: scale(0.98); }

.action-primary {
  background: var(--swancam-primary);
  box-shadow: 0 8rpx 32rpx rgba(255, 45, 85, 0.35);
}

.action-secondary {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.08);
}

.action-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.action-icon-circle,
.action-icon-square {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.action-primary .action-icon-circle {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}

.action-secondary .action-icon-square {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
}

.action-icon {
  font-size: 32rpx;
  color: #FFFFFF;
}

.action-text-group {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.action-primary .action-title  { color: #FFFFFF; font-size: 30rpx; font-weight: 700; }
.action-secondary .action-title { color: var(--swancam-text-primary); font-size: 30rpx; font-weight: 600; }
.action-primary .action-desc   { color: rgba(255, 255, 255, 0.65); font-size: 22rpx; }
.action-secondary .action-desc { color: var(--swancam-text-tertiary); font-size: 22rpx; }

.action-chevron { font-size: 40rpx; font-weight: 300; }
.action-primary .action-chevron   { color: rgba(255, 255, 255, 0.6); }
.action-secondary .action-chevron { color: rgba(255, 255, 255, 0.2); }

/* ── 功能标签 ────────────────────────────────── */
.feature-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 48rpx;
}

.feat-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.07);
  border-radius: 100rpx;
}

.feat-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--swancam-primary);
  flex-shrink: 0;
}

.feat-text {
  font-size: 22rpx;
  color: var(--swancam-text-tertiary);
}

/* ── 底部品牌 ────────────────────────────────── */
.footer-brand {
  margin-top: auto;
  padding: 24rpx 0 48rpx;
  text-align: center;
}

.footer-text {
  font-size: 22rpx;
  color: var(--swancam-text-tertiary);
  opacity: 0.5;
  letter-spacing: 1rpx;
}
