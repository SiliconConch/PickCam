/* pages/index/index.wxss  V2 Fresh Light Theme */

.index-page {
  min-height: 100vh;
  background: var(--fresh-bg);
  display: flex;
  flex-direction: column;
  padding: 0 32rpx calc(env(safe-area-inset-bottom) + 40rpx);
}

/* ── 顶部招呼区 ── */
.index-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(env(safe-area-inset-top) + 40rpx) 8rpx 32rpx;
}
.index-header-left { display: flex; flex-direction: column; gap: 6rpx; }
.index-greeting {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--fresh-text-primary);
  letter-spacing: 1rpx;
}
.index-date {
  font-size: 22rpx;
  color: var(--fresh-text-tertiary);
}
.streak-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: var(--fresh-sage-light);
  border: 1rpx solid var(--fresh-sage-mid);
  border-radius: var(--radius-full);
  padding: 10rpx 20rpx;
}
.streak-icon  { font-size: 22rpx; }
.streak-num   { font-size: 26rpx; font-weight: 700; color: var(--fresh-sage); }
.streak-label { font-size: 20rpx; color: var(--fresh-sage); }

/* ── 统计卡片 ── */
.stats-card {
  display: flex;
  align-items: center;
  background: var(--fresh-surface);
  border-radius: 32rpx;
  padding: 36rpx 0;
  margin-bottom: 32rpx;
  box-shadow: var(--fresh-shadow-sm);
}
.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--fresh-text-primary);
  line-height: 1;
}
.stat-label {
  font-size: 20rpx;
  color: var(--fresh-text-tertiary);
  letter-spacing: 1rpx;
}
.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: var(--fresh-border);
  flex-shrink: 0;
}

/* ── 操作按钮区 ── */
.action-area {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 36rpx;
}

/* 主按钮：拍摄 */
.action-camera {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--swancam-primary);
  border-radius: 28rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 10rpx 36rpx rgba(255,45,85,0.28);
  transition: transform 0.18s var(--ease-out-expo), opacity 0.18s;
}
.action-camera:active { transform: scale(0.97); opacity: 0.9; }

.action-camera-left { display: flex; align-items: center; gap: 24rpx; }
.camera-icon-wrap {
  width: 80rpx; height: 80rpx;
  background: rgba(255,255,255,0.18);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.camera-icon-sym { font-size: 40rpx; color: #FFFFFF; }

/* 次按钮：相册 */
.action-album {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--fresh-surface);
  border-radius: 28rpx;
  padding: 28rpx 28rpx;
  box-shadow: var(--fresh-shadow-sm);
  border: 1rpx solid var(--fresh-border);
  transition: transform 0.18s var(--ease-out-expo), opacity 0.18s;
}
.action-album:active { transform: scale(0.97); opacity: 0.85; }

.action-album-left { display: flex; align-items: center; gap: 24rpx; }
.album-icon-wrap {
  width: 80rpx; height: 80rpx;
  background: var(--fresh-sage-light);
  border-radius: 24rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.album-icon-sym { font-size: 38rpx; color: var(--fresh-sage); }

/* 通用文字列 */
.action-text-col  { display: flex; flex-direction: column; gap: 6rpx; }
.action-cam-title { font-size: 30rpx; font-weight: 700; color: #FFFFFF; }
.action-cam-desc  { font-size: 22rpx; color: rgba(255,255,255,0.65); }
.action-alb-title { font-size: 30rpx; font-weight: 600; color: var(--fresh-text-primary); }
.action-alb-desc  { font-size: 22rpx; color: var(--fresh-text-tertiary); }

.action-arrow     { font-size: 40rpx; font-weight: 300; color: rgba(255,255,255,0.55); }
.action-arrow-sub { color: var(--fresh-text-tertiary); }

/* ── 功能特性标签（sage green） ── */
.feature-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 48rpx;
}
.feat-pill {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 22rpx;
  background: var(--fresh-sage-light);
  border: 1rpx solid var(--fresh-sage-mid);
  border-radius: var(--radius-full);
}
.feat-pill-dot  { font-size: 24rpx; color: var(--fresh-sage); line-height: 1; }
.feat-pill-text { font-size: 22rpx; color: var(--fresh-sage); font-weight: 500; }

/* ── 底部品牌 ── */
.index-footer {
  margin-top: auto;
  padding: 16rpx 0 32rpx;
  text-align: center;
}
.index-footer-text {
  font-size: 22rpx;
  color: var(--fresh-text-tertiary);
  opacity: 0.6;
  letter-spacing: 1rpx;
}
