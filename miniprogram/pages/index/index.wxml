<!-- pages/index/index.wxml  V2 Fresh -->
<view class="index-page">

  <!-- 顶部：今日打招呼 + 连续天数 -->
  <view class="index-header">
    <view class="index-header-left">
      <text class="index-greeting">{{greeting}}</text>
      <text class="index-date">{{todayStr}}</text>
    </view>
    <view class="streak-badge" wx:if="{{streak > 0}}">
      <text class="streak-icon">🔥</text>
      <text class="streak-num">{{streak}}</text>
      <text class="streak-label">天</text>
    </view>
  </view>

  <!-- 统计卡片（仿参考图数据展示） -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-num">{{stats.photos}}</text>
      <text class="stat-label">作品</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.filters}}</text>
      <text class="stat-label">滤镜</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.watermarks}}</text>
      <text class="stat-label">水印</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{streak}}</text>
      <text class="stat-label">连续天</text>
    </view>
  </view>

  <!-- 主操作区 -->
  <view class="action-area">

    <!-- 拍摄（主 CTA） -->
    <view class="action-camera" bindtap="goCamera">
      <view class="action-camera-left">
        <view class="camera-icon-wrap">
          <text class="camera-icon-sym">◎</text>
        </view>
        <view class="action-text-col">
          <text class="action-cam-title">开始拍摄</text>
          <text class="action-cam-desc">实时取景 · 滤镜 · 倒计时</text>
        </view>
      </view>
      <text class="action-arrow">›</text>
    </view>

    <!-- 相册选图（次 CTA） -->
    <view class="action-album" bindtap="choosePhotos">
      <view class="action-album-left">
        <view class="album-icon-wrap">
          <text class="album-icon-sym">⊞</text>
        </view>
        <view class="action-text-col">
          <text class="action-alb-title">从相册选图</text>
          <text class="action-alb-desc">最多 {{maxPhotos}} 张批量处理</text>
        </view>
      </view>
      <text class="action-arrow action-arrow-sub">›</text>
    </view>

  </view>

  <!-- 功能特性标签（sage green 色调） -->
  <view class="feature-row">
    <view class="feat-pill" wx:for="{{features}}" wx:key="*this">
      <text class="feat-pill-dot">·</text>
      <text class="feat-pill-text">{{item}}</text>
    </view>
  </view>

  <!-- 底部品牌 -->
  <view class="index-footer">
    <text class="index-footer-text">拾光相机 · PickCam</text>
  </view>

</view>
