/* pages/camera/camera.wxss - Swancam Refined Aesthetic System */

/* 1. Top HUD - Ultra-Minimalist & Precision */
.top-control-center {
  position: absolute;
  top: calc(env(safe-area-inset-top) + var(--space-1));
  left: 50%;
  transform: translateX(-50%);
  height: 56rpx; /* 进一步压缩高度，追求极简 */
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  z-index: 150;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.4);
  background: rgba(44, 44, 46, 0.3); /* 更通透的背景 */
  backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255,255,255,0.05);
  transition: all 0.4s var(--ease-out-expo);
}

/* 经典模式下的 Top HUD：带有白色背景和黑色图标 */
.layout-classic .top-control-center {
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
  border-color: rgba(0,0,0,0.05);
}
.layout-classic .top-control-center view[class^="swancam-icon-"] {
  border-color: #333 !important;
}
.layout-classic .top-control-center .swancam-icon-flip::before,
.layout-classic .top-control-center .swancam-icon-flip::after,
.layout-classic .top-control-center .swancam-icon-layout::before {
  background-color: #333 !important;
  border-color: #333 !important;
}
.layout-classic .top-control-center .swancam-icon-flip::before {
  border-bottom-color: #333 !important;
  border-left-color: #333 !important;
}
.layout-classic .top-control-center .swancam-icon-flip::after {
  border-top-color: #333 !important;
  border-right-color: #333 !important;
}
.layout-classic .top-control-center .swancam-icon-reset::after {
  border-bottom-color: #333 !important;
  border-left-color: #333 !important;
}

/* 经典模式：取景器不再全屏，而是带有边框感 */
.layout-classic .camera-view {
  width: 92%;
  height: 70%;
  top: 15%;
  left: 4%;
  border-radius: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.5);
}

/* 经典模式下的操作区域背景 */
.layout-classic .bottom-console-wrap {
  background: #111;
  padding-top: 40rpx;
}
.top-action-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 100%;
}
.top-action-sep {
  width: 1rpx;
  height: 16rpx;
  background: rgba(255,255,255,0.1);
}

/* 具象化增强：精致图标覆盖层 */
.filter-visual-box::after {
  content: attr(data-icon);
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  font-size: 20rpx;
  opacity: 0.4;
  filter: grayscale(1);
  transition: all 0.3s;
}
.active .filter-visual-box::after {
  opacity: 1;
  filter: grayscale(0);
  transform: scale(1.2);
}

/* 1b. 专业参数条 - 极简数值展示 */
.pro-params-strip {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 68rpx);
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 0;
  z-index: 140;
  background: rgba(0, 0, 0, 0.28);
  border-radius: var(--radius-full);
  padding: 6rpx 4rpx;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}
.pro-param-chip {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  padding: 6rpx 20rpx;
  border-right: 1rpx solid rgba(255, 255, 255, 0.06);
}
.pro-param-chip:last-child { border-right: none; }
.ppc-label {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.35);
  font-weight: var(--font-weight-bold);
  letter-spacing: 1rpx;
}
.ppc-value {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: var(--font-weight-bold);
  font-variant-numeric: tabular-nums;
}

/* 参数说明浮层 */
.param-tip-panel {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 120rpx);
  left: 32rpx; right: 32rpx;
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  z-index: 160;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.param-tip-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}
.pti-label {
  font-size: 22rpx;
  color: var(--swancam-primary);
  font-weight: var(--font-weight-bold);
  width: 56rpx;
  flex-shrink: 0;
}
.pti-tip {
  font-size: 22rpx;
  color: var(--swancam-text-secondary);
  line-height: 1.5;
}

/* 2. Side HUD - Professional Iconography */
.side-hud-group {
  position: absolute;
  right: var(--space-3);
  top: 45%; /* 稍微靠上一点，避开右手握持区 */
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: var(--space-4); /* 增加间距，让操作更从容 */
  z-index: 200; /* 提高层级，确保在原生组件之上 */
  pointer-events: auto; /* 明确启用点击 */
}
.hud-item {
  width: 100rpx; /* 进一步确保点击热区足够大 */
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
  pointer-events: auto !important; /* 强制启用 */
  background: rgba(0, 0, 0, 0.01); /* 关键：即使透明也需要背景色来捕捉点击事件 */
  border-radius: 50%;
}
.hud-item > view, .hud-item > text {
  pointer-events: none; /* 确保点击穿透到父级 hud-item */
}

/* HUD 状态标签 */
.hud-item-label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.45);
  font-weight: var(--font-weight-bold);
  letter-spacing: 1rpx;
  margin-top: 4rpx;
  transition: color 0.3s;
}
.hud-item.active .hud-item-label {
  color: var(--swancam-primary);
}

/* 统一符号交互系统：侧边栏与底部图标复用滤镜的光斑逻辑 */
.hud-item .metaphor-icon-wrapper,
.atomic-action .metaphor-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

/* 侧边栏激活态光斑 */
.hud-item.active .metaphor-spotlight {
  width: 100%;
  height: 100%;
  background: var(--swancam-primary-light);
  box-shadow: 0 0 20rpx var(--swancam-primary-light);
}

.hud-item.active .metaphor-symbol {
  opacity: 1;
  filter: grayscale(0);
  transform: scale(1.1);
}

/* 底部操作项激活态光斑 */
.atomic-action:active .metaphor-spotlight {
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.15);
}

/* HUD/底部操作区的符号样式（侧边栏、相册、我的按钮） */
.metaphor-symbol {
  font-size: 44rpx;
  color: #FFFFFF;
  opacity: 0.5;
  z-index: 2;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

/* 3. 滤镜工作台（色块预览条，替代 emoji 图标） */
.bottom-console-wrap {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding-bottom: calc(env(safe-area-inset-bottom) + var(--space-2));
  z-index: 150;
  background: linear-gradient(to top, rgba(0,0,0,1) 0%, rgba(0,0,0,0.5) 60%, transparent 100%);
}
.filter-workbench {
  margin-bottom: var(--space-3);
}
.filter-list-inner {
  display: flex;
  padding: 20rpx var(--space-4);
  gap: 20rpx;
  align-items: center;
}

/* 滤镜条每一项 */
.filter-strip-item {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  transition: all 0.35s cubic-bezier(0.23, 1, 0.32, 1);
}
.filter-strip-item.active {
  transform: translateY(-10rpx);
}

/* 色块渐变圆 */
.filter-swatch-ring {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.15);
  padding: 4rpx;
  transition: border-color 0.3s, box-shadow 0.3s;
}
.filter-strip-item.active .filter-swatch-ring {
  border-color: var(--swancam-primary);
  box-shadow: 0 0 16rpx rgba(255,45,85,0.5);
}
.filter-swatch-circle {
  width: 100%; height: 100%;
  border-radius: 50%;
}

/* 滤镜名称 */
.filter-strip-name {
  font-size: 20rpx;
  color: rgba(255,255,255,0.4);
  transition: color 0.3s, opacity 0.3s;
  font-weight: var(--font-weight-med);
}
.filter-strip-item.active .filter-strip-name {
  color: var(--swancam-primary);
  opacity: 1;
}

/* 非活动项按压淡化 */
.filter-list-inner:active .filter-strip-item:not(.active) {
  opacity: 0.35;
}

/* 4. Core Interaction Row - Precision Shutter */
.core-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--space-6);
}
.atomic-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  min-width: 120rpx;
}

.atomic-label {
  font-size: 20rpx;
  color: #FFFFFF;
  opacity: 0.4;
  font-weight: var(--font-weight-med);
  transition: all 0.3s;
}

.atomic-action:active .atomic-label {
  opacity: 0.8;
}

/* 头像在具象隐喻下的特殊处理 */
.user-avatar-metaphor {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  z-index: 2;
  border: 2rpx solid rgba(255,255,255,0.1);
}

/* 精致快门组件：引入呼吸感光斑 */
.shutter-swancam-container {
  width: 180rpx;
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.shutter-spotlight {
  position: absolute;
  top: 50%; left: 50%;
  width: 140rpx; height: 140rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  z-index: 1;
  transition: all 0.5s ease;
}

.shutter-swancam-container:active .shutter-spotlight {
  width: 200rpx; height: 200rpx;
  background: radial-gradient(circle, rgba(255,45,85,0.15) 0%, transparent 75%);
}

.shutter-swancam-ring {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  border: 6rpx solid #FFFFFF;
  padding: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 20rpx rgba(0,0,0,0.2);
  z-index: 2;
  background: transparent;
}
.shutter-swancam-core {
  width: 100%;
  height: 100%;
  background: #FFFFFF;
  border-radius: 50%;
  transition: all 0.35s cubic-bezier(0.19, 1, 0.22, 1);
}
.shutter-swancam-core.is-recording {
  background: var(--swancam-primary);
  border-radius: 12rpx;
  transform: scale(0.6);
}

/* 5. Professional Swancam Iconography (2px Precision CSS) */
/* 顶部功能图标 - 保持 2px 精致线宽 */
.swancam-icon-flip {
  width: 32rpx; height: 32rpx;
  border: 3rpx solid #FFF; border-radius: 50%;
  border-top-color: transparent; border-bottom-color: transparent;
  position: relative;
}
.swancam-icon-flip::before, .swancam-icon-flip::after {
  content: ''; position: absolute;
  width: 0; height: 0; border: 6rpx solid transparent;
}
.swancam-icon-flip::before { top: -6rpx; left: 16rpx; border-bottom-color: #FFF; border-left-color: #FFF; }
.swancam-icon-flip::after { bottom: -6rpx; right: 16rpx; border-top-color: #FFF; border-right-color: #FFF; }

.swancam-icon-layout {
  width: 32rpx; height: 24rpx;
  border: 3rpx solid #FFF; border-radius: 4rpx;
  position: relative;
}
.swancam-icon-layout::before {
  content: ''; position: absolute;
  left: 50%; top: 0; width: 3rpx; height: 100%;
  background: #FFF; transform: translateX(-50%);
}

.swancam-icon-reset {
  width: 32rpx; height: 32rpx;
  border: 3rpx solid #FFF; border-radius: 50%;
  border-left-color: transparent;
  position: relative;
}
.swancam-icon-reset::after {
  content: ''; position: absolute;
  top: -6rpx; left: -2rpx;
  border: 6rpx solid transparent; border-bottom-color: #FFF; border-left-color: #FFF;
}

/* 6. 定时器自定义选择器样式 */
.timer-picker-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 300;
  display: flex; align-items: center; justify-content: center;
  backdrop-filter: blur(5px);
}
.timer-picker-card {
  width: 600rpx;
  padding: 40rpx;
  border-radius: 40rpx;
}
.timer-picker-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 40rpx;
}
.timer-picker-title { font-size: 32rpx; font-weight: bold; color: #FFF; }
.timer-picker-value { font-size: 40rpx; font-weight: bold; color: var(--swancam-primary); }
.timer-slider-wrap { margin-bottom: 40rpx; }
.timer-picker-actions { display: flex; gap: 20rpx; }
.timer-btn {
  flex: 1; height: 90rpx; line-height: 90rpx; text-align: center;
  border-radius: 20rpx; font-size: 28rpx; font-weight: bold;
}
.timer-btn-cancel { background: rgba(255,255,255,0.1); color: #AAA; }
.timer-btn-confirm { background: var(--swancam-primary); color: #FFF; }

/* 7. 倒计时覆盖层 */
.countdown-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 250;
  background: rgba(0, 0, 0, 0.25);
  pointer-events: none;
}
.countdown-num {
  font-size: 280rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.95);
  text-shadow:
    0 0 60rpx rgba(255, 45, 85, 0.6),
    0 0 120rpx rgba(255, 45, 85, 0.25);
  line-height: 1;
  animation: countdown-scale 1s var(--ease-out-expo) both;
}
@keyframes countdown-scale {
  from { transform: scale(1.4); opacity: 0; }
  to   { transform: scale(1);   opacity: 1; }
}

/* 8. 录像时长 HUD */
.recording-hud {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 80rpx);
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: rgba(0, 0, 0, 0.55);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: var(--radius-full);
  padding: 12rpx 32rpx;
  z-index: 200;
  border: 1rpx solid rgba(255, 45, 85, 0.3);
}
.rec-dot-pulse {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--swancam-primary);
  animation: rec-blink 1.2s ease-in-out infinite;
}
@keyframes rec-blink {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.3; transform: scale(0.75); }
}
.rec-time-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: var(--font-weight-bold);
  letter-spacing: 2rpx;
}

/* ── B1: 九宫格辅助线 ── */
.grid-overlay {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 8; pointer-events: none;
}
.grid-line { position: absolute; background: rgba(255,255,255,0.22); }
.gl-v1, .gl-v2 { top: 0; bottom: 0; width: 1rpx; }
.gl-h1, .gl-h2 { left: 0; right: 0; height: 1rpx; }
.gl-v1 { left: 33.33%; } .gl-v2 { left: 66.66%; }
.gl-h1 { top: 33.33%; }  .gl-h2 { top: 66.66%; }

/* ── B2: 水平仪 ── */
.level-bar {
  position: absolute; bottom: calc(env(safe-area-inset-bottom) + 420rpx);
  left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 12rpx;
  z-index: 180; pointer-events: none;
}
.level-track {
  width: 280rpx; height: 6rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 3rpx; position: relative;
  display: flex; align-items: center;
}
.level-center-mark {
  position: absolute; left: 50%; transform: translateX(-50%);
  width: 2rpx; height: 18rpx;
  background: rgba(255,255,255,0.4);
}
.level-bubble {
  width: 20rpx; height: 20rpx; border-radius: 50%;
  background: rgba(255,255,255,0.7);
  position: absolute; left: 50%; top: 50%;
  transform: translate(-50%, -50%);
  transition: transform 0.1s ease, background 0.3s;
}
.level-bubble.level-ok { background: #4CD964; }
.level-hint {
  font-size: 20rpx; color: rgba(255,255,255,0.5);
  letter-spacing: 1rpx;
}

/* ── B3: 画幅裁剪参考线 ── */
.ratio-guide {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 9; pointer-events: none;
}
.ratio-mask {
  position: absolute; left: 0; right: 0;
  background: rgba(0,0,0,0.5);
}
.ratio-mask-top    { top: 0; height: 18%; }
.ratio-mask-bottom { bottom: 0; height: 18%; }
.ratio-label-wrap {
  position: absolute; top: 22%; left: 24rpx;
}
.ratio-label {
  font-size: 22rpx; color: rgba(255,255,255,0.5);
  background: rgba(0,0,0,0.35); padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
}

/* ── S1: 更多功能面板（之前完全缺失） ── */
.more-panel-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.55); z-index: 300;
  display: flex; align-items: flex-end;
  backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
}
.more-panel-card {
  width: 100%;
  padding: 36rpx 32rpx calc(env(safe-area-inset-bottom) + 48rpx);
  border-radius: 40rpx 40rpx 0 0;
}
.more-panel-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 40rpx;
}
.more-panel-title {
  font-size: 32rpx; font-weight: var(--font-weight-bold); color: #FFF;
}
.more-panel-close {
  font-size: 28rpx; color: var(--swancam-text-tertiary); padding: 8rpx 8rpx;
}
.more-grid {
  display: flex; flex-wrap: wrap; gap: 24rpx;
}
.more-grid-item {
  display: flex; flex-direction: column; align-items: center; gap: 14rpx;
  width: calc(20% - 20rpx);
  position: relative;
}
.more-grid-icon-box {
  width: 96rpx; height: 96rpx;
  background: rgba(255,255,255,0.07);
  border-radius: var(--radius-md);
  border: 1rpx solid rgba(255,255,255,0.06);
  display: flex; align-items: center; justify-content: center;
  transition: background var(--duration-fast);
}
.more-grid-item:active .more-grid-icon-box { background: rgba(255,255,255,0.14); }
.more-grid-icon  { font-size: 36rpx; color: var(--swancam-text-primary); }
.more-grid-label { font-size: 20rpx; color: var(--swancam-text-secondary); text-align: center; }

/* R7: 更多面板激活态 */
.more-grid-item.func-active .more-grid-icon-box {
  background: var(--swancam-primary-light);
  border-color: rgba(255,45,85,0.25);
}
.more-grid-item.func-active .more-grid-label { color: var(--swancam-primary); }
.more-grid-item.func-active .more-grid-icon  { filter: none; }
.func-active-dot {
  position: absolute;
  top: 4rpx; right: 4rpx;
  width: 12rpx; height: 12rpx;
  border-radius: 50%;
  background: var(--swancam-primary);
}

/* ── B3: 画幅选择器 ── */
.ratio-picker-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 300;
  display: flex; align-items: flex-end;
  backdrop-filter: blur(6px);
}
.ratio-picker-card {
  width: 100%; padding: 32rpx 32rpx calc(env(safe-area-inset-bottom) + 32rpx);
  border-radius: 40rpx 40rpx 0 0;
}
.ratio-picker-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 40rpx;
}
.ratio-picker-title { font-size: 32rpx; font-weight: bold; color: #FFF; }
.ratio-picker-close { font-size: 28rpx; color: var(--swancam-text-tertiary); padding: 8rpx; }
.ratio-picker-grid  { display: flex; gap: 24rpx; justify-content: center; }
.ratio-option {
  display: flex; flex-direction: column; align-items: center; gap: 16rpx;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
  border: 2rpx solid transparent;
  background: rgba(255,255,255,0.05);
  transition: all var(--duration-fast);
}
.ratio-option.active { border-color: var(--swancam-primary); background: var(--swancam-primary-light); }
.ratio-thumb {
  background: rgba(255,255,255,0.15);
  border-radius: 4rpx;
  border: 1rpx solid rgba(255,255,255,0.2);
}
/* F2: 使用安全的 CSS 类名（不含冒号） */
.rt-full  { width: 56rpx; height: 72rpx; }
.rt-1-1   { width: 60rpx; height: 60rpx; }
.rt-4-3   { width: 64rpx; height: 48rpx; }
.rt-3-2   { width: 66rpx; height: 44rpx; }
.rt-16-9  { width: 72rpx; height: 40rpx; }
.ratio-name { font-size: 22rpx; color: var(--swancam-text-secondary); }
.ratio-option.active .ratio-name { color: var(--swancam-primary); font-weight: bold; }

/* ── C1: 全屏触控层 + 对焦圈 ── */
.camera-touch-layer {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 6;
}
.focus-ring {
  position: absolute;
  width: 88rpx; height: 88rpx;
  border: 2rpx solid rgba(255,230,0,0.9);
  border-radius: 4rpx;
  animation: focus-in 0.25s var(--ease-out-expo) both, focus-hold 1s 0.25s ease forwards;
  pointer-events: none;
}
@keyframes focus-in {
  from { transform: scale(1.6); opacity: 0; }
  to   { transform: scale(1);   opacity: 1; }
}
@keyframes focus-hold {
  0%   { border-color: rgba(255,230,0,0.9); }
  80%  { border-color: rgba(255,230,0,0.9); }
  100% { border-color: rgba(255,230,0,0.15); }
}

/* ── C2: 缩放指示器 ── */
.zoom-bar {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0,0,0,0.55);
  backdrop-filter: blur(12px);
  border-radius: var(--radius-full);
  padding: 14rpx 40rpx;
  pointer-events: none;
}
.zoom-text {
  font-size: 32rpx; font-weight: bold;
  color: #FFFFFF; letter-spacing: 2rpx;
}

/* ── F2: 滤镜名标注 ── */
.filter-name-badge {
  position: absolute;
  left: 32rpx;
  top: calc(env(safe-area-inset-top) + 130rpx);
  background: rgba(0,0,0,0.42);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-radius: var(--radius-full);
  padding: 8rpx 24rpx;
  z-index: 145;
  pointer-events: none;
  opacity: 0;
  transform: translateY(-8rpx);
  transition: opacity 0.3s ease, transform 0.3s var(--ease-out-expo);
}
.filter-name-badge.badge-show {
  opacity: 1;
  transform: translateY(0);
}
.filter-badge-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
  font-weight: var(--font-weight-med);
  letter-spacing: 1rpx;
}

/* 页面容器基础样式 */
.camera-page {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: #000;
  overflow: hidden;
}
.camera-view { width: 100%; height: 100%; z-index: 1; }

/* 相机权限错误页 */
.error-screen {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: var(--swancam-bg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 300;
  padding: var(--space-8);
  text-align: center;
}
.error-icon-big {
  font-size: 160rpx;
  color: var(--swancam-text-tertiary);
  margin-bottom: var(--space-4);
  opacity: 0.5;
}
.error-title {
  font-size: var(--font-size-h1);
  font-weight: var(--font-weight-bold);
  color: var(--swancam-text-primary);
  margin-bottom: var(--space-2);
}
.error-desc {
  font-size: var(--font-size-body);
  color: var(--swancam-text-secondary);
  margin-bottom: var(--space-8);
  line-height: 1.6;
}
.error-actions {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  width: 100%;
}
.err-btn {
  height: 100rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-body);
  font-weight: var(--font-weight-med);
  background: rgba(255, 255, 255, 0.08);
  color: var(--swancam-text-primary);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}
.err-btn:active { opacity: 0.7; }
.err-btn-primary {
  background: var(--swancam-primary);
  border-color: transparent;
  box-shadow: 0 8rpx 24rpx rgba(255, 45, 85, 0.3);
}
