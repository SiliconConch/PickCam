/* pages/about/about.wxss */
.about-page {
  min-height: 100vh;
  background: #0A0A0A;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 80rpx;
}

/* ── 导航栏 ── */
.about-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  box-sizing: border-box;
  padding: calc(env(safe-area-inset-top) + 24rpx) 32rpx 24rpx;
  background: rgba(10,10,10,0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1rpx solid rgba(255,255,255,0.05);
  position: sticky;
  top: 0;
  z-index: 100;
}
.about-nav-back {
  font-size: 52rpx;
  color: var(--swancam-text-primary);
  width: 64rpx;
  line-height: 1;
  padding: 0 8rpx;
}
.about-nav-back:active { opacity: 0.5; }
.about-nav-title {
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
  color: var(--swancam-text-primary);
  letter-spacing: 2rpx;
}
.about-nav-placeholder { width: 64rpx; }

/* ── Hero 区 ── */
.app-hero {
  display: flex; flex-direction: column; align-items: center;
  padding: 56rpx 0 40rpx;
  width: 100%;
}

.hero-logo {
  width: 160rpx; height: 160rpx;
  position: relative;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 28rpx;
}
.hero-ring {
  position: absolute; border-radius: 50%;
  border: 2rpx solid rgba(212,165,116,0.2);
}
.hr1 { width: 160rpx; height: 160rpx; animation: hrspin 16s linear infinite; }
.hr2 { width: 114rpx; height: 114rpx; border-color: rgba(212,165,116,0.38); animation: hrspin 10s linear infinite reverse; }
@keyframes hrspin { to { transform: rotate(360deg); } }
.hero-core {
  position: absolute;
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: radial-gradient(circle, rgba(212,165,116,0.72) 0%, rgba(212,165,116,0.18) 60%, transparent 100%);
  display: flex; align-items: center; justify-content: center;
}
.hero-dot {
  width: 26rpx; height: 26rpx; border-radius: 50%;
  background: #FFFFFF;
  box-shadow: 0 0 20rpx 6rpx rgba(255,255,255,0.5);
}

.app-name {
  font-size: 52rpx; font-weight: 700;
  color: #FFFFFF; letter-spacing: 6rpx;
  margin-bottom: 16rpx;
}
.version-badge {
  padding: 6rpx 24rpx;
  background: rgba(212,165,116,0.12);
  border: 1rpx solid rgba(212,165,116,0.3);
  border-radius: 100rpx;
  margin-bottom: 20rpx;
}
.version-text { font-size: 22rpx; color: #D4A574; }
.app-slogan   { font-size: 24rpx; color: rgba(255,255,255,0.35); letter-spacing: 1rpx; }

/* 分割线 */
.golden-rule {
  width: 64rpx; height: 2rpx;
  background: linear-gradient(90deg, transparent, #D4A574, transparent);
  border-radius: 1rpx;
  margin: 32rpx 0;
}

/* ── 特性列表 ── */
.features-section {
  width: 100%;
  padding: 0 32rpx;
  display: flex; flex-direction: column; gap: 0;
  margin-bottom: 32rpx;
}
.feature-item {
  display: flex; align-items: flex-start; gap: 24rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.feature-item:last-child { border-bottom: none; }
.feat-icon-wrap {
  width: 72rpx; height: 72rpx; border-radius: 18rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.fi-cam    { background: rgba(212,165,116,0.12); }
.fi-filter { background: rgba(93,190,163,0.10); }
.fi-wm     { background: rgba(155,140,210,0.10); }
.fi-cap    { background: rgba(232,180,80,0.10); }
.feat-icon { font-size: 32rpx; }
.feat-text  { display: flex; flex-direction: column; gap: 6rpx; padding-top: 6rpx; }
.feat-title { font-size: 28rpx; font-weight: 600; color: rgba(255, 255, 255, 0.85); }
.feat-desc  { font-size: 22rpx; color: rgba(255, 255, 255, 0.4); line-height: 1.5; }

/* ── 操作卡片 ── */
.action-section {
  display: flex; gap: 16rpx;
  padding: 0 32rpx;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 48rpx;
}
.about-card {
  flex: 1;
  background: #1A1A1A;
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 16rpx;
  padding: 28rpx 0;
  display: flex; flex-direction: column;
  align-items: center; gap: 10rpx;
}
.about-card:active { opacity: 0.7; }
.about-card-icon  { font-size: 32rpx; color: #D4A574; }
.about-card-label { font-size: 24rpx; color: rgba(255, 255, 255, 0.5); }

/* ── 底部 ── */
.about-footer {
  display: flex; flex-direction: column; align-items: center; gap: 10rpx;
}
.footer-made { font-size: 22rpx; color: rgba(255, 255, 255, 0.25); }
.footer-copy { font-size: 20rpx; color: rgba(255, 255, 255, 0.18); }
.footer-links {
  display: flex; align-items: center; gap: 12rpx;
  margin-top: 4rpx;
}
.footer-link { font-size: 20rpx; color: rgba(255, 255, 255, 0.3); }
.footer-sep  { font-size: 20rpx; color: rgba(255, 255, 255, 0.15); }
