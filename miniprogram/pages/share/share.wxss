/* pages/share/share.wxss - Swancam Dark Share Experience */

.share-page {
  min-height: 100vh;
  background: var(--swancam-bg);
  display: flex;
  flex-direction: column;
}

/* ========== 自定义导航栏 ========== */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(env(safe-area-inset-top) + 20rpx) 32rpx 20rpx;
  background: rgba(0, 0, 0, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-back {
  font-size: 32rpx;
  color: var(--swancam-primary);
  padding: 8rpx 0;
  font-weight: var(--font-weight-med);
}

.nav-title {
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
  color: var(--swancam-text-primary);
  letter-spacing: 2rpx;
}

.nav-right {
  width: 80rpx;
}

/* ========== 预览卡片 ========== */
.preview-card {
  margin: 32rpx;
  background: var(--swancam-surface);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.7);
  border: 1rpx solid var(--swancam-border);
  position: relative;
}

.share-image {
  width: 100%;
  max-height: 75vw;
  display: block;
}

.brand-watermark {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.55));
  padding: 40rpx 24rpx 20rpx;
  text-align: right;
}

.brand-watermark-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.65);
  letter-spacing: 1rpx;
}

/* ========== 提示文字 ========== */
.tip-text {
  text-align: center;
  font-size: 24rpx;
  color: var(--swancam-text-tertiary);
  margin: -8rpx 0 24rpx;
}

/* ========== C10: Pro 升级卡片 ========== */
.pro-upgrade-card {
  margin: 0 32rpx 28rpx;
  background: linear-gradient(135deg, rgba(255,45,85,0.12) 0%, rgba(230,126,34,0.08) 100%);
  border: 1rpx solid rgba(255,45,85,0.28);
  border-radius: var(--radius-lg);
  padding: 28rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(255,45,85,0.1);
}
.pro-card-left  { display: flex; align-items: center; gap: 20rpx; flex: 1; }
.pro-badge {
  font-size: 18rpx; font-weight: 700;
  color: var(--swancam-primary);
  background: var(--swancam-primary-light);
  border: 1rpx solid rgba(255,45,85,0.3);
  border-radius: var(--radius-sm);
  padding: 4rpx 12rpx;
  letter-spacing: 2rpx;
  flex-shrink: 0;
}
.pro-card-text  { display: flex; flex-direction: column; gap: 6rpx; }
.pro-card-title { font-size: 26rpx; font-weight: var(--font-weight-bold); color: var(--swancam-text-primary); }
.pro-card-desc  { font-size: 20rpx; color: var(--swancam-text-tertiary); }
.pro-card-btn {
  font-size: 24rpx; font-weight: var(--font-weight-bold);
  color: #FFFFFF;
  background: var(--swancam-primary);
  padding: 16rpx 36rpx;
  border-radius: var(--radius-full);
  box-shadow: 0 4rpx 16rpx rgba(255,45,85,0.35);
  flex-shrink: 0;
}
.pro-card-btn:active { opacity: 0.8; }

/* ========== 底部操作按钮组 ========== */
.action-row {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
  margin-top: auto;
  background: rgba(28, 28, 30, 0.95);
  backdrop-filter: blur(25px);
  -webkit-backdrop-filter: blur(25px);
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 24rpx 0;
  border-radius: var(--radius-md);
  border: none;
  line-height: 1;
  transition: transform var(--duration-fast) var(--ease-out-expo),
              opacity var(--duration-fast);
}

.action-btn::after {
  border: none;
}

.action-btn:active {
  transform: scale(0.94);
  opacity: 0.85;
}

.save-btn {
  background: var(--swancam-primary);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(255, 45, 85, 0.3);
}

.share-friend-btn {
  background: rgba(255, 255, 255, 0.08);
  color: var(--swancam-text-primary);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.home-btn {
  background: rgba(255, 255, 255, 0.05);
  color: var(--swancam-text-secondary);
  border: 1rpx solid rgba(255, 255, 255, 0.07);
}

.btn-icon {
  font-size: 36rpx;
}

.btn-text {
  font-size: 22rpx;
  font-weight: var(--font-weight-med);
  color: inherit;
}
